{
  "expo": {
    "name": "djassafoot",
    "slug": "djassafoot",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "djassafoot",
    "userInterfaceStyle": "dark",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.locagri.djassafoot",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.locagri.djassafoot",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0B",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A0A0B",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76,
            "backgroundColor": "#0A0A0B"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Djassa Foot accède à tes photos pour choisir le logo de ta ligue."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "backgroundColor": "#0A0A0B",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d589703a-45b4-4cd0-a6b7-93f25416728c"
      }
    },
    "owner": "lordblackwood2"
  }
}
