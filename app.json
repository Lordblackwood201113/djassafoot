{
  "expo": {
    "name": "djassafoot",
    "slug": "djassafoot",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo/djassafoot_mark.png",
    "scheme": "djassafoot",
    "userInterfaceStyle": "dark",
    "ios": {
      "bundleIdentifier": "com.locagri.djassafoot",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.locagri.djassafoot",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo/djassafoot_adaptive_fg.png",
        "backgroundColor": "#26262A"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo/djassafoot.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#0A0A0B",
          "android": {
            "image": "./assets/logo/djassafoot.png",
            "imageWidth": 240,
            "resizeMode": "contain",
            "backgroundColor": "#0A0A0B"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Djassa Foot accède à tes photos pour choisir le logo de ta ligue."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "backgroundColor": "#0A0A0B",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d589703a-45b4-4cd0-a6b7-93f25416728c"
      }
    },
    "owner": "lordblackwood2"
  }
}
